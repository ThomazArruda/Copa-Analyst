# Copa Analyst — Variáveis de Ambiente
# Copie para .env e preencha com seus valores

# Obrigatória
ANTHROPIC_API_KEY=sk-ant-...

# API-Football (free tier: 100 req/dia)
API_FOOTBALL_KEY=...

# Caminho do banco SQLite (default: dados/copa_analyst.db)
COPA_DB_PATH=dados/copa_analyst.db

# Desativa chamadas à API Anthropic — útil para desenvolver a UI sem gastar créditos
# MOCK_AI=true

# Modelo de síntese default (a UI pode escolher 'opus' por jogo). Default: claude-sonnet-4-6
# CLAUDE_MODEL=claude-sonnet-4-6

# Banda máxima de ajuste qualitativo em pontos percentuais (PRD Seção 2.2)
# Não alterar sem atualizar docs/DECISIONS.md Decisão 5
COPA_BAND_PP=0.10

# Autenticação do deploy público (grupo fechado). Se APP_PASSWORD existir,
# UI + API exigem login Basic. Deixe em branco para rodar local sem senha.
# APP_USER=copa
# APP_PASSWORD=troque-por-uma-senha-forte

# Email diário (Resend — resend.com, grátis até 3.000/mês)
# Remetente: verificar domínio próprio em resend.com, ou usar onboarding@resend.dev para testes
RESEND_API_KEY=re_...
EMAIL_REMETENTE=copa-analyst@seudominio.com
# Lista separada por vírgulas
EMAIL_DESTINATARIOS=amigo1@gmail.com,amigo2@gmail.com,amigo3@gmail.com
